{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "types": [
      "jest",
      "react",
      "react-native"
    ],
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src",
    "App.tsx",
    "jest.setup.ts",
    "__tests__"
  ]
}
